{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.nveil-ai/nveil",
  "description": "Data processing and visualization toolkit — 50+ chart types, raw data stays local.",
  "title": "NVEIL",
  "version": "1.1.2",
  "websiteUrl": "https://nveil.com",
  "repository": {
    "url": "https://github.com/nveil-ai/nveil-toolkit",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "nveil",
      "version": "1.1.2",
      "transport": { "type": "stdio" },
      "runtimeHint": "uvx",
      "packageArguments": [
        { "type": "positional", "value": "mcp" }
      ],
      "environmentVariables": [
        {
          "name": "NVEIL_API_KEY",
          "description": "NVEIL planning service API key. Obtain at https://nveil.com.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
